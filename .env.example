# MIS Commentary Agent - Environment Configuration
# Copy this file to .env and fill in your values

# AI/API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Optional: Google Sheets API (for data import)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# Optional: Power BI API (for report generation)
POWER_BI_CLIENT_ID=your_power_bi_client_id
POWER_BI_CLIENT_SECRET=your_power_bi_client_secret

# General Settings
DEFAULT_MODEL=gpt-4o
TEMPERATURE=0.3
MAX_TOKENS=4000

# Output Settings
OUTPUT_FORMAT=markdown
OUTPUT_DIR=./reports

# Compliance
DATA_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true
